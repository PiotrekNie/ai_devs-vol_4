{
  "mcpServers": {
    "eversis-collections": {
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "node",
        "third-party/github-collections/mcp/eversis-collections-mcp/dist/index.js"
      ],
      "type": "stdio"
    },
    "context7": {
      "type": "stdio",
      "command": "/bin/bash",
      "args": ["scripts/mcp-run.sh", "npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "/bin/bash",
      "args": ["scripts/mcp-run.sh", "npx", "-y", "@playwright/mcp@latest"],
      "type": "stdio"
    },
    "sequential-thinking": {
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "type": "stdio"
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "type": "http"
    },
    "pdf-reader": {
      "command": "/bin/bash",
      "args": ["scripts/mcp-run.sh", "npx", "-y", "@sylphx/pdf-reader-mcp"],
      "type": "stdio"
    }
  }
}
