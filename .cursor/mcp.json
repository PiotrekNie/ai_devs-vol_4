{
  "mcpServers": {
    "eversis-collections": {
      "command": "node",
      "args": [
        "${env:CURSOR_COLLECTIONS_HOME}/mcp/eversis-collections-mcp/dist/index.js"
      ],
      "type": "stdio",
      "env": {
        "CURSOR_COLLECTIONS_HOME": "${env:CURSOR_COLLECTIONS_HOME}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "type": "stdio"
    },
    "sequential-thinking": {
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "type": "stdio"
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "type": "http"
    },
    "pdf-reader": {
      "command": "/bin/bash",
      "args": [
        "scripts/mcp-run.sh",
        "npx",
        "-y",
        "@sylphx/pdf-reader-mcp"
      ],
      "type": "stdio"
    }
  },
  "inputs": []
}
