# ─────────────────────────────────────────────────────────────────────────────
# AI Devs agent-boilerplate — environment variables
# Copy to tasks/.env (already loaded by all tasks via --env-file=../.env)
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider (choose one; shared with tasks/config.js) ───────────────────────
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-v1-...
# AI_PROVIDER=openai          # or "openrouter" (auto-detected if omitted)

# ── Course hub ────────────────────────────────────────────────────────────────
# HUB_API_KEY=...             # required for submit_to_hub tool
# HUB_VERIFY_URL=https://hub.ag3nts.org/verify   # default shown

# ── Agent runtime ─────────────────────────────────────────────────────────────
# AGENT_MODEL=gpt-4o-mini                # default LLM model
# AGENT_VISION_MODEL=gpt-4o-mini         # model used by analyze_image_vision tool
# AGENT_MAX_ITERATIONS=10                # max ReAct loop iterations
# AGENT_MAX_TOOL_OUTPUT_CHARS=24000      # cap tool JSON appended to conversation
# AGENT_MAX_FILE_READ_CHARS=50000        # max chars returned by read_file
# AGENT_RETRY_BASE_DELAY_MS=1000         # base delay (ms) for exponential backoff
# AGENT_MAX_RETRY_ATTEMPTS=5             # max retry attempts on 429/503

# ── Observer/Reflector memory (extension; see src/agent/memory.ts) ────────────
# AGENT_OM_MODEL=gpt-4o-mini            # model for Observer/Reflector passes
# OBSERVER_THRESHOLD_TOKENS=30000       # seal conversation above this estimate
# REFLECTOR_THRESHOLD_TOKENS=60000      # compress journal above this estimate
