# Secrets and sensitive material (do not index)
.env
.env.*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.keystore

# Generated / vendor / large artifacts
node_modules/
dist/
coverage/
.next/
bun.lock
package-lock.json

# Lessons — large media assets, generated outputs, raw data not needed for task context
lessons/*/workspace/
lessons/*/output/
lessons/*/images/
lessons/*/.env*
lessons/03_04_gmail/evals/

# Markdowns — course lesson transcripts; skip to keep context window focused on task code
markdowns/

# MCP local server — compiled output (not source of truth)
mcp/eversis-collections-mcp/node_modules/
mcp/eversis-collections-mcp/dist/
